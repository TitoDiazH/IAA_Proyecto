# Conexión PostgreSQL de Supabase (Connect > Session pooler).
DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:PASSWORD@HOST.pooler.supabase.com:5432/postgres?sslmode=require

# Bucket privado de Supabase Storage. La clave secreta es exclusiva del backend.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_REEMPLAZAR
SUPABASE_STORAGE_BUCKET=Syllabus

# Opcional: cambiar origen permitido para el frontend.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Opcional: tamaño máximo de ZIP en MB.
MAX_UPLOAD_MB=100

# Configuración del análisis con IA.
AI_REQUEST_TIMEOUT_SECONDS=300
ANALYSIS_RETRY_DELAY_SECONDS=30
ANALYSIS_MAX_RETRIES=3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
